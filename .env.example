# Copy to .env and fill in your credentials.
# auth.py uses python-dotenv to load this automatically (load_dotenv() is called at module import).
ENPHASE_EMAIL=your@email.com
ENPHASE_PASSWORD=yourpassword

# SSE transport (NAS deployment) — these are set in docker-compose.yml but can be overridden here
# MCP_TRANSPORT=sse
# MCP_HOST=0.0.0.0
# MCP_PORT=8766
